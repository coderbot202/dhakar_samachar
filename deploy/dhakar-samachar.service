[Unit]
Description=Dhakar Samachar Flask App (Gunicorn)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/dhakar_samachar
EnvironmentFile=/var/www/dhakar_samachar/.env
ExecStart=/var/www/dhakar_samachar/.venv/bin/gunicorn -w 3 -b 127.0.0.1:8000 wsgi:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
